{
  "name": "teams-lite-web",
  "private": true,
  "type": "module",
  "scripts": {
    "gen:theme": "bun run scripts/gen-theme.ts",
    "dev": "bun run gen:theme && vite dev",
    "build": "bun run gen:theme && vite build",
    "start": "bun run server.ts",
    "mock": "bun run mock/server.ts",
    "typecheck": "bun run gen:theme && tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "bun run gen:theme && vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.3.0",
    "@hugeicons/core-free-icons": "^4.2.3",
    "@hugeicons/react": "^1.1.9",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-scroll-area": "^1.2.15",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.13",
    "@radix-ui/react-visually-hidden": "^1.2.8",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-start": "^1.168.32",
    "@tanstack/react-store": "^0.11.0",
    "@tanstack/react-virtual": "^3.14.7",
    "@tanstack/store": "^0.11.0",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/extension-underline": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5",
    "happy-dom": "^20.11.0",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.61.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.10"
  }
}
